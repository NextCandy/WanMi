{
  "name": "wanmi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "vite dev",
    "preview": "pnpm build && vite preview",
    "build": "vite build && tsx scripts/sanitize-build.ts",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm domains:verify && pnpm verify:no-demo-data",
    "deploy": "pnpm build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply wanmi-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply wanmi-db --remote",
    "db:backup": "tsx scripts/backup-d1.ts",
    "domains:parse": "tsx scripts/parse-domain-csv.ts",
    "domains:validate": "tsx scripts/validate-domain-csv.ts",
    "domains:report": "tsx scripts/report-domain-csv.ts",
    "domains:import:local": "tsx scripts/import-domain-csv.ts --local",
    "domains:import:remote": "tsx scripts/import-domain-csv.ts --remote",
    "domains:verify": "tsx scripts/verify-domain-import.ts --local",
    "verify:no-demo-data": "tsx scripts/verify-no-demo-data.ts",
    "verify:production": "tsx scripts/verify-production.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "csv-parse": "^7.0.1",
    "dayjs": "^1.11.21",
    "hono": "^4.12.28",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "simple-icons": "^16.26.0",
    "tldts": "^7.4.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.22",
    "eslint": "^10.6.0",
    "globals": "^17.4.0",
    "tsx": "^4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
